# Evantix API Environment Variables
# Copy this to .env and fill values

# ─── Database (Railway PostgreSQL) ───────────────────────
# Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/evantix?schema=public"

# ─── Redis ───────────────────────────────────────────────
# Railway provides this via a Redis plugin, or use REDIS_URL directly
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars!!"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars!!"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ─── App ─────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"

# CORS: comma-separated origins for multiple frontends
# Example production: "https://evantix.vercel.app,https://evantix.com"
CORS_ORIGIN="http://localhost:3000"

# ─── Upload (S3-compatible — optional, uses local disk by default) ───
UPLOAD_BUCKET="evantix-uploads"
UPLOAD_REGION="us-east-1"
UPLOAD_ENDPOINT=""
UPLOAD_ACCESS_KEY=""
UPLOAD_SECRET_KEY=""
